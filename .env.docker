# ===========================================================
# Vendora + InsForge — Docker Environment (localhost)
# ===========================================================
# CÓMO USAR:
#  1. cp .env.docker.example .env
#  2. Ajusta los secretos (JWT_SECRET, ENCRYPTION_KEY, ACCESS_API_KEY)
#  3. docker compose up -d --build
# ===========================================================

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=vendora_db_secret_change_me
POSTGRES_DB=insforge
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# PostgREST
# ---------------------------------------------------------------------------
POSTGREST_PORT=5430

# ---------------------------------------------------------------------------
# InsForge Backend
# ---------------------------------------------------------------------------
APP_PORT=7130
AUTH_PORT=7131
API_BASE_URL=
VITE_API_BASE_URL=http://localhost:7130

# ---------------------------------------------------------------------------
# Vendora (Next.js)
# ---------------------------------------------------------------------------
# URL pública para el frontend client-side (NEXT_PUBLIC_* se bakea en build)
NEXT_PUBLIC_INSFORGE_BASE_URL=http://localhost:7130

# ---------------------------------------------------------------------------
# Seguridad
# ---------------------------------------------------------------------------
JWT_SECRET=vendora_jwt_secret_change_in_production_min_32_chars
ENCRYPTION_KEY=vendora_encryption_key_change_in_production_min_32_x
ACCESS_API_KEY=ik_vendora_docker_local_dev_key_1234567890abc

# ---------------------------------------------------------------------------
# Admin (se crea automáticamente al arrancar InsForge)
# ---------------------------------------------------------------------------
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password-now

# ---------------------------------------------------------------------------
# Deno (Edge Functions)
# ---------------------------------------------------------------------------
DENO_PORT=7133
DENO_ENV=production
WORKER_TIMEOUT_MS=60000

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------
MAX_FILE_SIZE=52428800
MAX_JSON_BODY_SIZE=100mb
MAX_URLENCODED_BODY_SIZE=10mb

# ---------------------------------------------------------------------------
# Opcionales (Cloud / OAuth / AI / Deployments) — dejar vacío para uso local
# ---------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=
AWS_CLOUDFRONT_URL=
AWS_CLOUDFRONT_KEY_PAIR_ID=
AWS_CLOUDFRONT_PRIVATE_KEY=
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
OPENROUTER_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=
DEPLOYMENT_ID=
PROJECT_ID=
APP_KEY=
CLOUD_API_HOST=
DENO_SUBHOSTING_TOKEN=
DENO_SUBHOSTING_ORG_ID=
VITE_PUBLIC_POSTHOG_KEY=
